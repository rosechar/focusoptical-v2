# Resend credentials for the appointment request form (app/api/appointment/route.ts).
# Get an API key at https://resend.com — copy this file to .env.local and fill in.
RESEND_API_KEY=

# Where owner notifications are sent.
OWNER_EMAIL=

# "From" address for outgoing mail, e.g. "Focus Optical <appointments@focusopticalrochesterhills.com>".
# Requires a domain verified in Resend; use "Focus Optical <onboarding@resend.dev>" for testing.
RESEND_FROM_EMAIL=
